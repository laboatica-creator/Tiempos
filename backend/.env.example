# Database Configuration
DATABASE_URL=postgres://user:password@host:port/tiemposdb

# Server Configuration
PORT=4000
NODE_ENV=development

# JWT Secrets
JWT_SECRET=supersecret
JWT_REFRESH_SECRET=supersecret_refresh

# WhatsApp Webhook & Notifications
ADMIN_WHATSAPP_NUMBER=506XXXXXXXXX
WHATSAPP_API_TOKEN=tu_token
WHATSAPP_VERIFY_TOKEN=verification_token

# OCR Data
OCR_API_KEY=tu_api_key
OCR_SERVICE_URL=https://api.ocr.space/parse/image

# Timezone default
TZ=America/Costa_Rica

# Reportes
REPORT_PAGE_SIZE=50
REPORT_CACHE_TTL=3600

# Frontend
NEXT_PUBLIC_ADMIN_WHATSAPP=506XXXXXXXXX
NEXT_PUBLIC_DEFAULT_DATE_RANGE=30
